rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'saransh1860@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /consultations/{consultationId} {
      allow create: if request.resource.data.name is string && request.resource.data.createdAt is timestamp;
      allow get, list, delete: if isAdmin();
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    match /contacts/{contactId} {
      allow create: if request.resource.data.name is string && request.resource.data.createdAt is timestamp;
      allow get, list, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
    }
  }
}
